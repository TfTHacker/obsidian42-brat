{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strict": true,
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "lib": ["es2022", "DOM", "ES5", "ES6", "ES7"],
    "types": ["@obsidian-typings/obsidian-public-latest"]
  },
  "include": ["**/*.ts", "src/types.d.ts"]
}
