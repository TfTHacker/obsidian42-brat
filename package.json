{
  "name": "obsidian42-brat",
  "version": "0.0.0",
  "description": "Obsidian42 - Beta Reviewer's Autoupdate Tool.",
  "main": "main.js",
  "scripts": {
    "dev": "npm run build:dev",
    "build": "npm run build:main",
    "build:dev": "node --no-warnings esbuild.config.mjs",
    "build:beta": "node --no-warnings esbuild.config.mjs beta",
    "build:main": "node --no-warnings esbuild.config.mjs production",
    "lint": "npm run lint:biome && npm run lint:eslint",
    "lint:biome": "biome check ./src",
    "lint:eslint": "eslint ."
  },
  "author": "TfT Hacker",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/TfTHacker/obsidian42-brat.git"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@eslint/js": "^9.39.1",
    "@obsidian-typings/obsidian-public-1.11.4": "^4.93.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^24.3.1",
    "@types/semver": "^7.7.1",
    "builtin-modules": "5.0.0",
    "conventional-changelog-conventionalcommits": "^10.0.0",
    "esbuild": "0.28.1",
    "esbuild-copy-static-files": "^0.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "globals": "^17.0.0",
    "jiti": "^2.7.0",
    "jsdom": "^26.1.0",
    "obsidian": "1.11.4",
    "semantic-release": "^25.0.5",
    "semantic-release-obsidian-plugin": "github:brianrodri/semantic-release-obsidian-plugin",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.12",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.46.4"
  },
  "dependencies": {
    "semver": "^7.7.2"
  },
  "overrides": {
    "obsidian": "1.11.4"
  }
}
